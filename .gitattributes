# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Archivos de codigo: siempre LF en el repositorio
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.svg   text eol=lf

# Archivos binarios: nunca modificar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
